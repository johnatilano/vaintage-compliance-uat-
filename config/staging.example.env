# Copy to .env and fill in before Phase 2 staging runs.
# Ask John Robinson for the Azure OpenAI staging deployment.

AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=o4-mini-staging
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ZDR contract — must be false / disabled for compliance
OPENAI_STORE=false
AZURE_DATA_LOGGING=disabled

# Optional: path to Guard test executable for guard adapter
# Falls back to scripts/guard_test_stub.py when unset
GUARD_TEST_EXE=

# Phase 2 live Azure ping (test_live_zdr_request) — ask John if ZDR is enabled
AZURE_OPENAI_API_KEY=

# Phase 3 heavy session (default 1000 notes when RUN_HEAVY=1)
HEAVY_SESSION_COUNT=1000
RUN_HEAVY=0

# Phase 2 live integration test gates
RUN_LIVE_ZDR=0

# Include system TEMP in disk watch (slow on some machines)
UAT_WATCH_TEMP=0
