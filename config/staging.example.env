# Copy to .env and fill in before Phase 2 staging runs.
# Ask John Robinson for the Azure OpenAI staging deployment.

AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=o4-mini-staging
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ZDR contract — must be false / disabled for compliance
OPENAI_STORE=false
AZURE_DATA_LOGGING=disabled

# Optional: path to Guard test executable for guard adapter
GUARD_TEST_EXE=
